// ENDPOINT 3: /api/quiz
// ============================================================
app.post('/api/quiz', async (req, res) => {
  try {
    const { text, lang, userName } = req.body;
    
    if (!text) {
      return res.status(400).json({ error: 'Text is required' });
    }

    const studentName = userName || 'Student';

    const quizPrompt = `Based on this study material, generate an exam-grade quiz.

MATERIAL:
"""${text.slice(0, 4000)}"""

RULES:
- Write ALL questions in REAL ENGLISH — like a proper university exam
- Use proper English grammar and vocabulary
- Questions must be the same style as real exams
- Exactly 5 questions in this order: easy, medium, medium, killer, killer
- MCQ options must have exactly 4 choices

Return ONLY valid JSON:
{
  "questions": [
    {
      "type": "mcq",
      "difficulty": "easy",
      "question": "What does CLT stand for?",
      "options": ["Central Learning Theory", "Central Limit Theorem", "Common Logic Test", "None of the above"],
      "correctAnswer": "Central Limit Theorem"
    },
    {
      "type": "mcq",
      "difficulty": "medium",
      "question": "Question 2...",
      "options": ["A", "B", "C", "D"],
      "correctAnswer": "A"
    },
    {
      "type": "fill",
      "difficulty": "medium",
      "question": "Question with ____ blank...",
      "correctAnswer": "Answer here"
    },
    {
      "type": "theory",
      "difficulty": "killer",
      "question": "Question...",
      "correctAnswer": "Model answer here"
    },
    {
      "type": "mcq",
      "difficulty": "killer",
      "question": "Question...",
      "options": ["A", "B", "C", "D"],
      "correctAnswer": "C"
    }
  ]
}`;

    const result = await callGemini(quizPrompt);
    let cleaned = result.replace(/```json/g, '').replace(/```/g, '').trim();
    const parsed = JSON.parse(cleaned);
    const questions = parsed.questions;

    const langInstruction = lang === 'pidgin'
      ? 'Write in NATURAL NIGERIAN PIDGIN ENGLISH. Use "na", "dey", "wey", "abeg", "oya". NO English at all.'
      : 'Write in SIMPLE ENGLISH. NO Pidgin at all. Use simple words.';

    for (let q of questions) {
      const wrongOptions = q.options ? q.options.filter(o => o !== q.correctAnswer) : [];

      let explainPrompt;
      
      if (lang === 'pidgin') {
        explainPrompt = `Explain why the answer is correct for this exam question. Write in PIDGIN ENGLISH.

QUESTION: ${q.question}
CORRECT ANSWER: ${q.correctAnswer}
${wrongOptions.length > 0 ? 'WRONG OPTIONS: ' + wrongOptions.join(', ') : ''}
STUDENT NAME: ${studentName}

RULES:
- Start with: "${studentName}, make I explain am o!"
- If wrong options: say "❌ [wrong option] no correct because..." for each wrong option
- Say "✅ [correct answer] correct because..." and explain
- Include simple meaning if technical term
- End with encouragement

Write the explanation in PIDGIN ENGLISH only:`;
      } else {
        explainPrompt = `Explain why the answer is correct for this exam question. Write in SIMPLE ENGLISH.

QUESTION: ${q.question}
CORRECT ANSWER: ${q.correctAnswer}
${wrongOptions.length > 0 ? 'WRONG OPTIONS: ' + wrongOptions.join(', ') : ''}
STUDENT NAME: ${studentName}

RULES:
- Start with: "${studentName}, let me explain!"
- If wrong options: say "❌ [wrong option] is wrong because..." for each wrong option
- Say "✅ [correct answer] is correct because..." and explain
- Include simple meaning if technical term
- End with encouragement

Write the explanation in SIMPLE ENGLISH only:`;
      }

      const explanation = await callGemini(explainPrompt);
      q.explanation = explanation;
      q.why = explanation;
    }

    res.json({
      success: true,
      questions: questions,
      apiUsed: 'gemini'
    });

  } catch (error) {
    console.error('❌ Quiz error:', error);
    res.status(500).json({ error: error.message });
  }
});

