// ============================================================
// CALL GEMINI API (Using Fetch - Same as Curl)
// ============================================================
async function callGemini(prompt) {
  try {
    const response = await fetch('https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-goog-api-key': GEMINI_API_KEY
      },
      body: JSON.stringify({
        contents: [{
          parts: [{
            text: prompt
          }]
        }]
      })
    });

    const data = await response.json();
    
    if (!response.ok) {
      throw new Error(`Gemini error: ${data.error?.message || response.status}`);
    }

    return data.candidates?.[0]?.content?.parts?.[0]?.text || 'No response';
  } catch (error) {
    console.error('❌ Gemini error:', error);
    throw error;
  }
}

// ============================================================
// DETECT TOPIC
// ============================================================
async function detectTopic(text) {
  try {
    const prompt = `What is the main topic of this text? Return only the topic name (2-5 words), nothing else. TEXT: ${text.slice(0, 1000)}`;
    const result = await callGemini(prompt);
    return result.trim() || 'Your topic';
  } catch (error) {
    console.error('Topic detection error:', error);
    return 'Your topic';
  }
}

// ============================================================
// GENERATE ALL LEVELS AT ONCE (1 API Call!)
// ============================================================
async function generateAllLevels(text, topic, studentName, lang) {
  const langInstruction = lang === 'pidgin'
    ? 'Write in NATURAL NIGERIAN PIDGIN ENGLISH only. Use "na", "dey", "wey", "abeg", "oya".'
    : 'Write in SIMPLE ENGLISH only. Use "is", "are", "the".';

  const levels = {};

  // LEVEL 0: Normal summary
  const level0Prompt = `You are a friendly tutor named "LTC" talking to a student named ${studentName}.

TOPIC: ${topic}
LANGUAGE: ${lang === 'pidgin' ? 'PIDGIN' : 'ENGLISH'}

${langInstruction}

Write a clear, easy-to-understand summary of this text. Use everyday analogies (market, traffic, cooking, factory, soup).

TEXT: ${text.slice(0, 6000)}

RULES:
- Start by saying: "${studentName}, this topic is about... [topic]"
- Call the student by name at least 3-4 times
- Format technical terms like **[Term]** (Meaning: *simple explanation*)
- Do not add a title. Just the friendly explanation.`;

  const level0 = await callGemini(level0Prompt);

  // LEVEL 1: Simpler
  const level1Prompt = `This is LEVEL 1 breakdown for a student named ${studentName} who said "I NO UNDERSTAND".

TOPIC: ${topic}

${langInstruction}

Make this EVEN SIMPLER than the previous explanation. Use smaller words. Use more analogies.

PREVIOUS EXPLANATION:
"""${level0}"""

RULES:
- Start with: "${studentName}, make I explain am another way..."
- Use even more everyday examples
- Call the student by name often
- Keep the format: **[Term]** (Meaning: *simple explanation*)`;

  const level1 = await callGemini(level1Prompt);

  // LEVEL 2: Even simpler
  const level2Prompt = `This is LEVEL 2 breakdown for ${studentName}. They still don't understand. Make it EVEN SIMPLER.

TOPIC: ${topic}

${langInstruction}

Explain like you dey talk to a 10-year-old. Use very basic words. Use real-life examples they see every day.

PREVIOUS EXPLANATION:
"""${level1}"""

RULES:
- Start with: "${studentName}, no worry! Let me try again..."
- Use very simple words
- Add more analogies
- Break into small steps`;

  const level2 = await callGemini(level2Prompt);

  // LEVEL 3: Small pikin explanation
  const level3Prompt = `This is LEVEL 3 breakdown for ${studentName}. They STILL don't understand. Make it SUPER SIMPLE.

TOPIC: ${topic}

${langInstruction}

Explain like you dey talk to a 5-year-old. Use the simplest words possible. Use one simple analogy.

PREVIOUS EXPLANATION:
"""${level2}"""

RULES:
- Start with: "${studentName}, abeg listen small o! Na wetin e mean be say..."
- Use very basic words
- One simple analogy
- Call the student by name at least 2 times
- Keep the format: **[Term]** (Meaning: *very simple explanation*)`;

  const level3 = await callGemini(level3Prompt);

  levels.level0 = level0;
  levels.level1 = level1;
  levels.level2 = level2;
  levels.level3 = level3;

  return levels;
}

