app.post('/api/cook', async (req, res) => {
  try {
    const { text, title, lang, userName } = req.body;
    
    if (!text) {
      return res.status(400).json({ error: 'Text is required' });
    }

    const studentName = userName || 'Student';
    const topic = await detectTopic(text);
    console.log('📌 Topic detected:', topic);

    const levels = await generateAllLevels(text, topic, studentName, lang);

    res.json({
      success: true,
      topic: topic,
      levels: levels,
      apiUsed: 'gemini'
    });

  } catch (error) {
    console.error('❌ Cook error:', error);
    res.status(500).json({ error: error.message });
  }
});

